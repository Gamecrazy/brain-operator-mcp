# Required
THEBRAIN_API_KEY=replace_with_your_thebrain_api_key

# Cloud API by default
THEBRAIN_BASE_URL=https://api.bra.in
THEBRAIN_MODE=cloud

# Local API used by local desktop app-control tools.
THEBRAIN_LOCAL_BASE_URL=http://localhost:8001/api

# Optional default brain id. If omitted, tools require brainId or user must call list_brains first.
THEBRAIN_DEFAULT_BRAIN_ID=

# MCP server
MCP_SERVER_NAME=brain-operator-mcp
MCP_SERVER_VERSION=0.1.0
PORT=3000

# Security
WRITE_TOOLS_ENABLED=true
DESTRUCTIVE_TOOLS_ENABLED=false
MAX_NOTE_CHARS=10000
MAX_SEARCH_RESULTS=50
MAX_PLAN_CHANGES=100
PLAN_TTL_MINUTES=30
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=.data/audit.log
PLAN_STORE_PATH=.data/plans.json

# Optional server auth for remote MCP endpoint.
# If set, clients must send Authorization: Bearer <MCP_API_TOKEN>
MCP_API_TOKEN=

# Dev logging
LOG_LEVEL=info
NODE_ENV=development
